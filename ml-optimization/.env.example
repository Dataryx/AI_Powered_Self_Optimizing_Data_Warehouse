# ML Optimization API — recommendations & WebSocket (copy to .env or set in process env)
#
# Real-time ML recommendations need:
# 1) Artifacts in saved_models/ (query_time_predictor.pkl or query_time_predictor_xgboost.json; optional anomaly_detector.pkl)
# 2) Fresh ml_optimization.query_logs — run scripts/ml-optimization/run_query_collection.py (e.g. --forever --poll-seconds 3)
# 3) Warehouse workload — scripts/ml-optimization/run_traffic_and_collection.py or your app traffic
#
# POSTGRES_* — same as utils/db_utils (host, port, db, user, password)

# Live ML on GET /optimization/recommendations and WebSocket (default: on)
# OPTIMIZATION_LIVE_ON_RECOMMENDATIONS_GET=1

# Where live ML samples workload from (default: both)
#   query_logs — ml_optimization.query_logs only (collector must keep this fresh)
#   pg_stat    — pg_stat_statements only (fresher; requires extension)
#   both       — half/half merge, deduped by query text (pg_stat rows first)
# OPTIMIZATION_ML_LIVE_SOURCE=both

# Max rows sampled for live ML per request (default 30000)
# OPTIMIZATION_QUERY_LOG_LIMIT=30000

# Only use query_logs collected in the last N hours (unset = all)
# OPTIMIZATION_QUERY_LOG_LOOKBACK_HOURS=24

# Non-ML pg_stat_user_tables merge into recommendations (default: off for ML-only story)
# OPTIMIZATION_MERGE_PG_STAT_LIVE=0

# WebSocket optimization snapshot interval (ms, default 2000)
# OPTIMIZATION_WS_INTERVAL_MS=2000

# Max live recommendation rows per response cap (default 300)
# OPTIMIZATION_LIVE_RECOMMENDATIONS_CAP=300

# Hide recommendations whose leading column already has a B-tree (default on in code; set 0 to list all)
# OPTIMIZATION_FILTER_REDUNDANT_INDEXES=0

# Add catalog RANGE-partition hints for tables seen in live index ML (default: 1). Set 0 to disable.
# OPTIMIZATION_AUGMENT_PARTITION_HINTS_FROM_WORKLOAD=1
