# Copy to .env and adjust if your ML API is not on the default host/port.
# Default matches start_services.py (uvicorn on port 8000).

VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional: poll Analytics bundle on this interval (milliseconds). Omit or 0 = no polling. Minimum 5000.
# VITE_ANALYTICS_POLL_MS=60000

# Optional: WebSocket origin only if it differs from VITE_API_BASE_URL (otherwise WS is inferred: http→ws).
# VITE_WS_BASE_URL=ws://localhost:8001

# --- Alerts & incidents (real data) ---
# 1) Postgres must match POSTGRES_* in ml-optimization / start_services (warehouse DB with bronze/silver/gold, monitoring.job_runs, ml_optimization.query_logs).
# 2) From repo root: python start_services.py  (serves the ML API so this URL works.)
# 3) If /alerts/page-bundle fails, the dashboard falls back to /alerts/active, /alerts/anomalies, /alerts/incidents.
# 4) Optional: seed query logs for slow-query + ML anomaly signals:
#    python scripts/ml-optimization/populate_query_logs_fast.py
